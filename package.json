{
  "name": "openclaw-okf",
  "version": "0.2.2",
  "description": "OKF (Open Knowledge Format) plugin for OpenClaw — structured knowledge bundles with auto-recall, graph traversal, and agent tools",
  "type": "module",
  "main": "dist/index.js",
  "files": ["dist", "skills", "openclaw.plugin.json", "README.md", "LICENSE"],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.5.12"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "keywords": [
    "openclaw",
    "okf",
    "open-knowledge-format",
    "knowledge-graph",
    "agent-memory"
  ],
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
